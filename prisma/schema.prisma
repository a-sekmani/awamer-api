generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS (16)
// ============================================================================

enum UserStatus {
  ACTIVE     @map("active")
  INACTIVE   @map("inactive")
  SUSPENDED  @map("suspended")

  @@map("user_status")
}

enum Role {
  LEARNER @map("learner")
  ADMIN   @map("admin")

  @@map("role")
}

enum CategoryStatus {
  ACTIVE @map("active")
  HIDDEN @map("hidden")

  @@map("category_status")
}

enum PathStatus {
  DRAFT     @map("draft")
  PUBLISHED @map("published")
  ARCHIVED  @map("archived")

  @@map("path_status")
}

enum CourseStatus {
  DRAFT     @map("draft")
  PUBLISHED @map("published")
  ARCHIVED  @map("archived")

  @@map("course_status")
}

enum LessonType {
  TEXT        @map("text")
  VIDEO       @map("video")
  INTERACTIVE @map("interactive")
  MIXED       @map("mixed")

  @@map("lesson_type")
}

enum ContentFormat {
  MARKDOWN    @map("markdown")
  HTML        @map("html")
  VIDEO       @map("video")
  CODE        @map("code")
  IMAGE       @map("image")
  INTERACTIVE @map("interactive")

  @@map("content_format")
}

enum EnrollmentStatus {
  ACTIVE    @map("active")
  COMPLETED @map("completed")
  PAUSED    @map("paused")

  @@map("enrollment_status")
}

enum ProgressStatus {
  NOT_STARTED @map("not_started")
  IN_PROGRESS @map("in_progress")
  COMPLETED   @map("completed")

  @@map("progress_status")
}

enum QuizType {
  SECTION_QUIZ @map("section_quiz")
  COURSE_EXAM  @map("course_exam")

  @@map("quiz_type")
}

enum QuestionType {
  SINGLE_CHOICE   @map("single_choice")
  MULTIPLE_CHOICE @map("multiple_choice")

  @@map("question_type")
}

enum AttemptStatus {
  IN_PROGRESS @map("in_progress")
  PASSED      @map("passed")
  FAILED      @map("failed")

  @@map("attempt_status")
}

enum SubmissionStatus {
  SUBMITTED @map("submitted")
  REVIEWED  @map("reviewed")

  @@map("submission_status")
}

enum BillingCycle {
  FREE      @map("free")
  MONTHLY   @map("monthly")
  QUARTERLY @map("quarterly")
  YEARLY    @map("yearly")

  @@map("billing_cycle")
}

enum SubscriptionStatus {
  ACTIVE    @map("active")
  CANCELLED @map("cancelled")
  EXPIRED   @map("expired")
  PAST_DUE  @map("past_due")

  @@map("subscription_status")
}

enum PaymentStatus {
  COMPLETED @map("completed")
  FAILED    @map("failed")
  REFUNDED  @map("refunded")

  @@map("payment_status")
}

enum RateLimitType {
  FORGOT_PASSWORD      @map("forgot_password")
  VERIFICATION_RESEND  @map("verification_resend")

  @@map("rate_limit_type")
}

// ============================================================================
// USER DOMAIN (4 models)
// ============================================================================

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  passwordHash String
  country      String?
  locale       String     @default("ar")
  status       UserStatus @default(ACTIVE)
  emailVerified          Boolean    @default(false)
  refreshToken       String?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  failedLoginAttempts  Int        @default(0)
  lockedUntil          DateTime?
  lastLoginAt          DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  profile              UserProfile?
  roles                UserRole[]
  onboardingResponses  OnboardingResponse[]
  emailVerifications   EmailVerification[]
  pathEnrollments      PathEnrollment[]
  lessonProgress       LessonProgress[]
  sectionProgress      SectionProgress[]
  courseProgress        CourseProgress[]
  pathProgress         PathProgress[]
  lastPositions        LastPosition[]
  quizAttempts         QuizAttempt[]
  projectSubmissions   ProjectSubmission[]
  subscriptions        Subscription[]
  payments             Payment[]
  certificates         Certificate[]

  @@index([email])
  @@map("users")
}

model RateLimitedRequest {
  id        String        @id @default(uuid())
  email     String
  ip        String
  type      RateLimitType
  createdAt DateTime      @default(now())

  @@index([type, email, createdAt])
  @@index([type, ip, createdAt])
  @@map("rate_limited_requests")
}

model EmailVerification {
  id        String   @id @default(uuid())
  userId    String
  code      String   @db.VarChar(6)
  expiresAt DateTime
  attempts  Int      @default(0)
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, used, expiresAt])
  @@map("email_verifications")
}

model UserProfile {
  id                  String   @id @default(uuid())
  userId              String   @unique
  displayName         String?
  avatarUrl           String?
  background          String?
  goals               String?
  interests           String?
  preferredLanguage   String?
  onboardingCompleted Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_profiles")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  role      Role
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([userId])
  @@map("user_roles")
}

model OnboardingResponse {
  id          String   @id @default(uuid())
  userId      String
  questionKey String
  answer      String
  stepNumber  Int
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("onboarding_responses")
}

// ============================================================================
// CONTENT HIERARCHY (6 models)
// ============================================================================

model Category {
  id          String         @id @default(uuid())
  name        String
  slug        String         @unique
  description String?
  icon        String?
  order       Int            @default(0)
  status      CategoryStatus @default(ACTIVE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  paths Path[]

  @@map("categories")
}

model Path {
  id             String     @id @default(uuid())
  categoryId     String
  title          String
  slug           String     @unique
  description    String?
  level          String?
  thumbnail      String?
  estimatedHours Int?
  is_free        Boolean    @default(false)
  status         PathStatus @default(DRAFT)
  order          Int        @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  category        Category         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  courses         Course[]
  pathEnrollments PathEnrollment[]
  pathProgress    PathProgress[]
  lastPositions   LastPosition[]
  certificates    Certificate[]

  @@index([categoryId])
  @@map("paths")
}

model Course {
  id          String       @id @default(uuid())
  pathId      String
  title       String
  description String?
  order       Int          @default(0)
  is_free     Boolean      @default(false)
  status      CourseStatus @default(DRAFT)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  path           Path             @relation(fields: [pathId], references: [id], onDelete: Cascade)
  sections       Section[]
  quizzes        Quiz[]
  courseProgress  CourseProgress[]
  lastPositions  LastPosition[]
  projects       Project[]

  @@index([pathId])
  @@map("courses")
}

model Section {
  id        String   @id @default(uuid())
  courseId   String
  title     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course          Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons         Lesson[]
  quizzes         Quiz[]
  sectionProgress SectionProgress[]
  lastPositions   LastPosition[]

  @@index([courseId])
  @@map("sections")
}

model Lesson {
  id               String     @id @default(uuid())
  sectionId        String
  title            String
  type             LessonType
  order            Int        @default(0)
  is_free          Boolean    @default(false)
  estimatedMinutes Int?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  section        Section              @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  contentBlocks  LessonContentBlock[]
  lessonProgress LessonProgress[]
  lastPositions  LastPosition[]

  @@index([sectionId])
  @@map("lessons")
}

model LessonContentBlock {
  id        String        @id @default(uuid())
  lessonId  String
  format    ContentFormat
  body      String?
  videoUrl  String?
  metadata  Json?
  order     Int           @default(0)
  version   Int           @default(1)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@map("lesson_content_blocks")
}

// ============================================================================
// PROGRESS & ENROLLMENT (7 models)
// ============================================================================

model PathEnrollment {
  id         String           @id @default(uuid())
  userId     String
  pathId     String
  status     EnrollmentStatus @default(ACTIVE)
  enrolledAt DateTime         @default(now())
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  path Path @relation(fields: [pathId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([pathId])
  @@map("path_enrollments")
}

model LessonProgress {
  id          String         @id @default(uuid())
  userId      String
  lessonId    String
  status      ProgressStatus @default(NOT_STARTED)
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@map("lesson_progress")
}

model SectionProgress {
  id               String         @id @default(uuid())
  userId           String
  sectionId        String
  completedLessons Int            @default(0)
  totalLessons     Int            @default(0)
  percentage       Float          @default(0)
  status           ProgressStatus @default(NOT_STARTED)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([userId, sectionId])
  @@index([userId])
  @@index([sectionId])
  @@map("section_progress")
}

model CourseProgress {
  id                String         @id @default(uuid())
  userId            String
  courseId           String
  completedSections Int            @default(0)
  totalSections     Int            @default(0)
  percentage        Float          @default(0)
  status            ProgressStatus @default(NOT_STARTED)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("course_progress")
}

model PathProgress {
  id               String         @id @default(uuid())
  userId           String
  pathId           String
  completedCourses Int            @default(0)
  totalCourses     Int            @default(0)
  percentage       Float          @default(0)
  status           ProgressStatus @default(NOT_STARTED)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  path Path @relation(fields: [pathId], references: [id], onDelete: Cascade)

  @@unique([userId, pathId])
  @@index([userId])
  @@index([pathId])
  @@map("path_progress")
}

model LastPosition {
  id         String   @id @default(uuid())
  userId     String
  pathId     String
  courseId    String
  sectionId  String
  lessonId   String
  accessedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  path    Path    @relation(fields: [pathId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  lesson  Lesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, pathId])
  @@index([userId])
  @@index([pathId])
  @@map("last_positions")
}

model Certificate {
  id              String   @id @default(uuid())
  userId          String
  pathId          String
  certificateCode String   @unique
  certificateUrl  String?
  issuedAt        DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  path Path @relation(fields: [pathId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([pathId])
  @@map("certificates")
}

// ============================================================================
// ASSESSMENT (4 models)
// ============================================================================

model Quiz {
  id               String   @id @default(uuid())
  courseId          String
  sectionId        String?
  title            String
  type             QuizType
  passingScore     Int
  timeLimitMinutes Int?
  questionCount    Int      @default(0)
  order            Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  section  Section? @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  questions    Question[]
  quizAttempts QuizAttempt[]

  @@index([courseId])
  @@index([sectionId])
  @@map("quizzes")
}

model Question {
  id          String       @id @default(uuid())
  quizId      String
  body        String
  type        QuestionType
  explanation String?
  order       Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  quiz    Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options Option[]

  @@index([quizId])
  @@map("questions")
}

model Option {
  id         String   @id @default(uuid())
  questionId String
  body       String
  isCorrect  Boolean  @default(false)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("options")
}

model QuizAttempt {
  id          String        @id @default(uuid())
  userId      String
  quizId      String
  score       Int?
  status      AttemptStatus @default(IN_PROGRESS)
  answers     Json?
  startedAt   DateTime      @default(now())
  completedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([quizId])
  @@map("quiz_attempts")
}

// ============================================================================
// PROJECTS (2 models)
// ============================================================================

model Project {
  id          String   @id @default(uuid())
  courseId     String
  title       String
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course      Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  submissions ProjectSubmission[]

  @@index([courseId])
  @@map("projects")
}

model ProjectSubmission {
  id             String           @id @default(uuid())
  userId         String
  projectId      String
  submissionData Json
  status         SubmissionStatus @default(SUBMITTED)
  submittedAt    DateTime         @default(now())
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
  @@map("project_submissions")
}

// ============================================================================
// SUBSCRIPTIONS & PAYMENTS (3 models)
// ============================================================================

model SubscriptionPlan {
  id            String         @id @default(uuid())
  name          String
  billingCycle  BillingCycle
  price         Float
  currency      String         @default("USD")
  durationDays  Int
  isDefault     Boolean        @default(false)
  stripePriceId String?
  status        CategoryStatus @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  subscriptions Subscription[]
  payments      Payment[]

  @@map("subscription_plans")
}

model Subscription {
  id                   String             @id @default(uuid())
  userId               String
  planId               String
  status               SubscriptionStatus @default(ACTIVE)
  stripeSubscriptionId String?
  stripeCustomerId     String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan     SubscriptionPlan @relation(fields: [planId], references: [id])
  payments Payment[]

  @@index([userId])
  @@index([planId])
  @@map("subscriptions")
}

model Payment {
  id                    String        @id @default(uuid())
  userId                String
  subscriptionId        String
  planId                String
  amount                Float
  currency              String        @default("USD")
  status                PaymentStatus
  stripePaymentIntentId String?
  paidAt                DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription     @relation(fields: [subscriptionId], references: [id])
  plan         SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([userId])
  @@index([subscriptionId])
  @@index([planId])
  @@map("payments")
}
