# Database
DATABASE_URL=postgresql://ahmadsekmani@localhost:5432/awamer  # PostgreSQL connection string

# JWT Authentication
JWT_SECRET=change-me-to-a-long-random-string          # Access token signing secret
JWT_REFRESH_SECRET=change-me-to-a-different-string     # Refresh token signing secret
JWT_EXPIRATION=900                                     # Access token TTL in seconds (default: 15 min)
JWT_REFRESH_EXPIRATION=7d                              # Refresh token TTL (default: 7 days)

# Stripe Payments
STRIPE_SECRET_KEY=sk_test_placeholder                  # Stripe API secret key
STRIPE_WEBHOOK_SECRET=whsec_placeholder                # Stripe webhook signing secret

# AWS
AWS_ACCESS_KEY_ID=placeholder                          # AWS IAM access key
AWS_SECRET_ACCESS_KEY=placeholder                      # AWS IAM secret key
AWS_REGION=eu-west-1                                   # AWS region for S3 and SES
S3_BUCKET_NAME=awamer-files                            # S3 bucket for file uploads
SES_FROM_EMAIL=noreply@awamer.com                      # SES verified sender email

# Analytics
POSTHOG_API_KEY=phc_placeholder                        # PostHog project API key

# Application
FRONTEND_URL=http://localhost:3000                     # Frontend origin for CORS
PORT=3001                                              # HTTP server port

# Rate Limiting
THROTTLE_TTL=60000                                     # Rate limit window in milliseconds
THROTTLE_LIMIT=100                                     # Max requests per window per IP